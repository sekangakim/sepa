##   Figure 1 — Parallel analysis (Section 4.2)
##   Figure 2 — Bootstrap stability diagnostics (Section 4.3)
##   Figure 3 — ALSI distribution histogram (Section 4.4)
##
## Runtime:
##   Parallel analysis  (B = 2000): ~ 45 seconds
##   Bootstrap stability(B = 2000): ~ 120 seconds
##   ALSI computation:              < 1 second
##   Total estimated runtime:       ~ 3-4 minutes
##
## Platform:
##   Tested on: R version 4.5.2 (2026-01-15), Ubuntu 24.04 LTS
##   No platform-specific dependencies.
##
## Random seed: 20260123 used throughout for full reproducibility.
## =============================================================================
## =============================================================================
## 0. Setup
## =============================================================================
if (!requireNamespace("alsi", quietly = TRUE)) install.packages("alsi")
library("alsi")
cat("alsi package version:", as.character(packageVersion("alsi")), "\n")
## Expected: 0.1.3
## =============================================================================
## Section 4.1 — Data Structure
## =============================================================================
cat("\n=============================================================\n")
cat("SECTION 4.1 — Data Structure\n")
cat("=============================================================\n")
data("ANR2", package = "alsi")
vars <- c("MDD", "DYS", "DEP", "PTSD", "OCD", "GAD", "ANX", "SOPH", "ADHD")
cat("\nDimensions: N =", nrow(ANR2), "individuals,",
ncol(ANR2), "total columns,", length(vars), "diagnostic variables\n")
cat("\nhead(ANR2[, vars]):\n")
print(head(ANR2[, vars]))
prev <- colMeans(ANR2[, vars], na.rm = TRUE)
cat("\nDiagnosis prevalence:\n")
print(round(prev, 3))
cat("Most common:  MDD (", round(max(prev) * 100, 1), "%)\n", sep = "")
cat("Least common: DYS (", round(min(prev) * 100, 1), "%)\n", sep = "")
## Expected: MDD = 44.3%, DYS = 4.7%
## =============================================================================
## Section 4.2 — Parallel Analysis and Dimension Retention
## Produces: Figure 1
## =============================================================================
cat("\n=============================================================\n")
cat("SECTION 4.2 — Parallel Analysis (B = 2000, q = 0.95)\n")
cat("=============================================================\n")
## Figure 1 is produced automatically inside mca_pa() below
set.seed(20260123)
pa <- mca_pa(ANR2,
vars    = vars,
B       = 2000,
q       = 0.95,
seed    = 20260123,
verbose = TRUE)
## ^^^ Figure 1 now displayed
cat("\nFull parallel analysis results:\n")
print(pa)
## Expected: K* = 3
cat("\nObserved eigenvalues:\n")
print(round(pa$eig_obs, 6))
cat("\nReference quantiles (95th pct):\n")
print(round(pa$eig_q, 6))
cat("\nRetained K*:", pa$K_star, "\n")
pct_inertia <- sum(pa$eig_obs[1:pa$K_star]) / sum(pa$eig_obs)
cat("\nProportion of total inertia (K* =", pa$K_star, "dims):",
round(pct_inertia * 100, 1), "%\n")
## Expected: 48.2%
## =============================================================================
## Section 4.3 — Subspace Stability Diagnostics
## Produces: Figure 2 (K* = 3 dimensions only)
## =============================================================================
cat("\n=============================================================\n")
cat("SECTION 4.3 — Bootstrap Stability (B = 2000, K = 3)\n")
cat("=============================================================\n")
boot <- mca_bootstrap(ANR2,
vars    = vars,
K       = pa$K_star,
B       = 2000,
seed    = 20260123,
verbose = TRUE)
## Table 3 — Principal angles summary
cat("\n--- Table 3 (top panel): Principal Angles (degrees) ---\n")
print(round(boot$angles_summary, 2))
## Expected:
##        median   p5   p95
## theta1   2.77 1.31  5.04
## theta2   6.94 3.88 12.25
## theta3  15.46 8.87 33.72
## Table 3 — Tucker congruence coefficients summary
cat("\n--- Table 3 (bottom panel): Tucker Congruence Coefficients ---\n")
print(round(boot$tucker_summary, 3))
## Expected:
##      median    p5   p95
## phi1  0.992 0.965 0.998
## phi2  0.978 0.894 0.995
## phi3  0.980 0.826 0.996
## Figure 2: pass only the K*=3 columns explicitly to ensure exactly
## 3 boxplots per panel, matching the manuscript figure
cat("\nGenerating Figure 2: Bootstrap stability (3 dimensions)...\n")
boot_3 <- boot
boot_3$angles <- boot$angles[, 1:pa$K_star, drop = FALSE]
boot_3$tucker <- boot$tucker[, 1:pa$K_star, drop = FALSE]
plot_subspace_stability(boot_3)
## ^^^ Figure 2 now displayed (3 dimensions only)
## Full quantile verification
cat("\n--- Tucker full quantile profiles ---\n")
for (k in 1:boot$K) {
qv <- quantile(boot$tucker[, k], probs = c(0.05, 0.50, 0.95), na.rm = TRUE)
cat(sprintf("  phi%d  min:%.4f  p5:%.4f  median:%.4f  p95:%.4f  max:%.4f\n",
k, min(boot$tucker[, k], na.rm = TRUE),
qv["5%"], qv["50%"], qv["95%"],
max(boot$tucker[, k], na.rm = TRUE)))
}
cat("\n--- Principal Angles full quantile profiles ---\n")
for (k in 1:boot$K) {
qv <- quantile(boot$angles[, k], probs = c(0.05, 0.50, 0.95), na.rm = TRUE)
cat(sprintf("  theta%d  min:%.3f  p5:%.3f  median:%.3f  p95:%.3f  max:%.3f\n",
k, min(boot$angles[, k], na.rm = TRUE),
qv["5%"], qv["50%"], qv["95%"],
max(boot$angles[, k], na.rm = TRUE)))
}
## =============================================================================
## Section 4.4 — ALSI Computation
## Produces: Figure 3
## =============================================================================
cat("\n=============================================================\n")
cat("SECTION 4.4 — ALSI Computation\n")
cat("=============================================================\n")
fit      <- boot$ref
alsi_obj <- alsi(fit$F, fit$eig, K = pa$K_star)
cat("\nprint(alsi_obj):\n")
print(alsi_obj)
## Expected:
##   K = 3 dimensions, N = 1261 individuals
##   Variance weights: 0.4345 0.2979 0.2676
##   ALSI range: [0.0398, 1.6252]
##   ALSI mean: 0.3731, ALSI median: 0.3681
cat("\nsummary(alsi_obj$alpha):\n")
print(summary(alsi_obj$alpha))
cat("\nVariance weights (sum =", round(sum(alsi_obj$w), 6), "):\n")
print(round(alsi_obj$w, 6))
## Figure 3: ALSI distribution histogram (matches manuscript Figure 3)
cat("\nGenerating Figure 3: ALSI distribution histogram...\n")
hist(alsi_obj$alpha,
breaks = 40,
main   = "Distribution of ALSI Values (N = 1261)",
xlab   = expression("ALSI value (" * alpha * ")"),
ylab   = "Frequency",
col    = "steelblue",
border = "white")
abline(v = median(alsi_obj$alpha), lty = 2, col = "red", lwd = 2)
legend("topright",
legend = c(sprintf("Median = %.3f", median(alsi_obj$alpha)),
sprintf("Min = %.4f",    min(alsi_obj$alpha)),
sprintf("Max = %.4f",    max(alsi_obj$alpha)),
sprintf("Mean = %.4f",   mean(alsi_obj$alpha))),
bty = "n", cex = 0.85)
## ^^^ Figure 3 now displayed
## =============================================================================
## Section 4.5 — Category Projections
## Note: projection table only — no biplot produced here
## =============================================================================
cat("\n=============================================================\n")
cat("SECTION 4.5 — Category Projections (top 10)\n")
cat("=============================================================\n")
## Compute projections directly (no plot produced)
Gk   <- fit$G[, 1:pa$K_star, drop = FALSE]
proj <- drop(Gk %*% alsi_obj$alpha_vec)
ord  <- order(abs(proj), decreasing = TRUE)
cat("\nTop 10 categories by |projection onto ALSI direction|:\n")
print(data.frame(Category   = rownames(Gk)[ord[1:10]],
Projection = round(proj[ord[1:10]], 4)),
row.names = FALSE)
## Expected top: ADHD_1 (-2.0696), DYS_1 (-1.1949), DEP_1 (-0.9841), ...
cat("\n--- Full projection table (all 18 categories) ---\n")
print(data.frame(Category   = rownames(Gk)[ord],
Projection = round(proj[ord], 4)),
row.names = FALSE)
## =============================================================================
## Section 4.6 — Downstream Analyses
## =============================================================================
cat("\n=============================================================\n")
cat("SECTION 4.6 — Downstream Analyses\n")
cat("=============================================================\n")
ANR2$alpha <- alsi_obj$alpha
cat("\n--- Model 1: post_EDI ~ pre_EDI + alpha ---\n")
fit_edi <- lm(post_EDI ~ pre_EDI + alpha, data = ANR2)
print(summary(fit_edi))
cat("\nEDI alpha coefficient:\n")
print(round(coef(summary(fit_edi))["alpha", ], 4))
## Expected: Estimate ~ 14.45, p = 0.005
cat("\n--- Model 2: post_bmi ~ pre_bmi + alpha ---\n")
fit_bmi <- lm(post_bmi ~ pre_bmi + alpha, data = ANR2)
print(summary(fit_bmi))
cat("\nBMI alpha coefficient:\n")
print(round(coef(summary(fit_bmi))["alpha", ], 4))
## Expected: Estimate ~ -0.01, p = 0.943
## =============================================================================
## Section 4.7 — Complete Workflow via alsi_workflow()
## Note: all plots produced internally by alsi_workflow() are suppressed
##       here using pdf(NULL)/dev.off() to avoid duplicating Figures 1-3
##       and the category biplot already produced above.
## =============================================================================
cat("\n=============================================================\n")
cat("SECTION 4.7 — Complete Workflow via alsi_workflow()\n")
cat("=============================================================\n")
## Redirect graphics to null device to suppress duplicate figures
pdf(NULL)
results <- alsi_workflow(ANR2,
vars   = vars,
B_pa   = 2000,
B_boot = 2000,
seed   = 20260123)
dev.off()
cat("\nWorkflow output components:\n")
cat("  pa$K_star    =", results$pa$K_star,  "\n")
cat("  boot$K       =", results$boot$K,     "\n")
cat("  alsi$K       =", results$alsi$K,     "\n")
cat("  K (retained) =", results$K,          "\n")
## Expected: all = 3
## =============================================================================
## Session Information
## =============================================================================
cat("\n=============================================================\n")
cat("SESSION INFORMATION\n")
cat("=============================================================\n")
sessionInfo()
## =============================================================================
## Replication Script for:
## "The Aggregated Latent Space Index: Software for Stability-Validated
##  Aggregation in Multiple Correspondence Analysis"
## Journal of Statistical Software (Submitted)
##
## Author:  Se-Kang Kim
##          Department of Pediatrics, Baylor College of Medicine
##          se-kang.kim@bcm.edu
##
## Package: alsi version 0.1.3
##          https://CRAN.R-project.org/package=alsi
##          DOI: https://doi.org/10.32614/CRAN.package.alsi
##
## Figures produced (exactly once, in manuscript order):
##   Figure 1 — Parallel analysis scree plot        (Section 4.2)
##   Figure 2 — Bootstrap stability boxplots        (Section 4.3)
##   Figure 3 — ALSI distribution histogram         (Section 4.4)
##
## Runtime:  ~ 3-4 minutes (B = 2000 throughout)
## Platform: R >= 4.0.0, no platform-specific dependencies
## Seed:     20260123 used throughout
## =============================================================================
## =============================================================================
## 0. Setup
## =============================================================================
if (!requireNamespace("alsi", quietly = TRUE)) install.packages("alsi")
library("alsi")
stopifnot(packageVersion("alsi") == "0.1.3")
## =============================================================================
## Replication Script for:
## "The Aggregated Latent Space Index: Software for Stability-Validated
##  Aggregation in Multiple Correspondence Analysis"
## Journal of Statistical Software (Submitted)
##
## Author:  Se-Kang Kim
##          Department of Pediatrics, Baylor College of Medicine
##          se-kang.kim@bcm.edu
##
## Package: alsi version 0.1.3
##          https://CRAN.R-project.org/package=alsi
##          DOI: https://doi.org/10.32614/CRAN.package.alsi
##
## Figures produced (exactly once, in manuscript order):
##   Figure 1 — Parallel analysis scree plot        (Section 4.2)
##   Figure 2 — Bootstrap stability boxplots        (Section 4.3)
##   Figure 3 — ALSI distribution histogram         (Section 4.4)
##
## Runtime:  ~ 3-4 minutes (B = 2000 throughout)
## Platform: R >= 4.0.0, no platform-specific dependencies
## Seed:     20260123 used throughout
## =============================================================================
## =============================================================================
## 0. Setup
## =============================================================================
if (!requireNamespace("alsi", quietly = TRUE)) install.packages("alsi")
library("alsi")
stopifnot(packageVersion("alsi") == "0.1.2")
cat("alsi version confirmed: 0.1.2\n")
## =============================================================================
## Section 4.1 — Data structure
## =============================================================================
cat("\n--- Section 4.1: Data structure ---\n")
data("ANR2", package = "alsi")
vars <- c("MDD", "DYS", "DEP", "PTSD", "OCD", "GAD", "ANX", "SOPH", "ADHD")
cat("\nhead(ANR2[, vars]):\n")
print(head(ANR2[, vars]))
cat("\nPrevalence:\n")
print(round(colMeans(ANR2[, vars], na.rm = TRUE), 3))
## Expected: MDD = 0.443 (most common), DYS = 0.047 (least common)
## =============================================================================
## Section 4.2 — Parallel analysis
## Figure 1 is produced automatically inside mca_pa() — exactly once here
## =============================================================================
cat("\n--- Section 4.2: Parallel analysis ---\n")
## NOTE: mca_pa() always plots Figure 1 internally. We call it once here.
## verbose = FALSE suppresses console clutter; K_star and % inertia shown below.
pa <- mca_pa(ANR2, vars = vars, B = 2000, q = 0.95,
seed = 20260123, verbose = FALSE)
## ^^^ Figure 1 displayed here
cat("K* retained:", pa$K_star, "\n")
## Expected: K* = 3
cat("Observed eigenvalues (dims 1-5):\n")
print(round(pa$eig_obs[1:5], 4))
cat("Reference quantiles (dims 1-5):\n")
print(round(pa$eig_q[1:5], 4))
pct <- round(sum(pa$eig_obs[1:pa$K_star]) / sum(pa$eig_obs) * 100, 1)
cat("Proportion of total inertia (K* = 3 dims):", pct, "%\n")
## Expected: 48.2%
## =============================================================================
## Section 4.3 — Bootstrap stability diagnostics
## Figure 2 reproduced with custom code matching the manuscript figure exactly:
##   - Title:  "Subspace Stability: Procrustes Principal Angles" (left)
##             "Dimension Stability: Tucker's Congruence Coefficients" (right)
##   - x-axis: "Dim 1", "Dim 2", "Dim 3"
##   - Exactly 3 boxplots per panel
## =============================================================================
cat("\n--- Section 4.3: Bootstrap stability ---\n")
## verbose = FALSE avoids re-printing the summary tables already shown below
boot <- mca_bootstrap(ANR2, vars = vars, K = pa$K_star,
B = 2000, seed = 20260123, verbose = FALSE)
## Table 3 — principal angles
cat("\nTable 3 (top): Principal Angles (degrees)\n")
print(round(boot$angles_summary, 2))
## Expected:
##        median   p5   p95
## theta1   2.77 1.31  5.04
## theta2   6.94 3.88 12.25
## theta3  15.46 8.87 33.72
## Table 3 — Tucker congruence coefficients
cat("\nTable 3 (bottom): Tucker Congruence Coefficients\n")
print(round(boot$tucker_summary, 3))
## Expected:
##      median    p5   p95
## phi1  0.992 0.965 0.998
## phi2  0.978 0.894 0.995
## phi3  0.980 0.826 0.996
## Figure 2: custom plot matching manuscript exactly
## Uses boot$angles and boot$tucker which have exactly K*=3 columns
cat("\nGenerating Figure 2...\n")
op <- par(mfrow = c(1, 2),
mar   = c(4.5, 4.5, 3.5, 1))
## Left panel — principal angles
boxplot(boot$angles,
names  = paste("Dim", 1:pa$K_star),
main   = "Subspace Stability:\nProcrustes Principal Angles",
xlab   = "",
ylab   = "Principal angle (degrees)",
col    = "lightblue",
border = "darkblue",
ylim   = c(0, max(boot$angles, na.rm = TRUE) * 1.05))
abline(h = 0, lty = 2, col = "gray50")
## Right panel — Tucker congruence coefficients
boxplot(boot$tucker,
names  = paste("Dim", 1:pa$K_star),
main   = "Dimension Stability:\nTucker's Congruence Coefficients",
xlab   = "",
ylab   = expression("Tucker's congruence coefficient (" * phi * ")"),
col    = "lightgreen",
border = "darkgreen",
ylim   = c(0.2, 1.0))
abline(h = c(0.95, 0.85), lty = 2,
col = c("red", "orange"))
legend("bottomleft",
legend = c(expression(phi * " = 0.95  excellent"),
expression(phi * " = 0.85  fair")),
lty = 2, col = c("red", "orange"),
bty = "n", cex = 0.8)
par(op)
## ^^^ Figure 2 displayed here (Dim 1 / Dim 2 / Dim 3, exactly 3 per panel)
## =============================================================================
## Section 4.4 — ALSI computation
## Figure 3 produced with custom histogram matching the manuscript
## =============================================================================
cat("\n--- Section 4.4: ALSI computation ---\n")
fit      <- boot$ref
alsi_obj <- alsi(fit$F, fit$eig, K = pa$K_star)
cat("\nprint(alsi_obj):\n")
print(alsi_obj)
## Expected:
##   K = 3, N = 1261
##   Variance weights: 0.4345 0.2979 0.2676
##   ALSI range: [0.0398, 1.6252]
##   ALSI mean: 0.3731,  ALSI median: 0.3681
cat("\nsummary(alsi_obj$alpha):\n")
print(summary(alsi_obj$alpha))
## Expected:
##    Min. 1st Qu.  Median    Mean 3rd Qu.    Max.
##  0.0398  0.2727  0.3681  0.3731  0.4310  1.6252
cat("\nVariance weights (sum =", round(sum(alsi_obj$w), 6), "):\n")
print(round(alsi_obj$w, 4))
## Figure 3: ALSI histogram matching manuscript
cat("\nGenerating Figure 3...\n")
hist(alsi_obj$alpha,
breaks = 40,
main   = "Distribution of ALSI Values (N = 1261)",
xlab   = expression("ALSI value (" * alpha * ")"),
ylab   = "Frequency",
col    = "steelblue",
border = "white")
abline(v = median(alsi_obj$alpha), lty = 2, col = "red", lwd = 2)
legend("topright",
legend = c(sprintf("Median = %.3f", median(alsi_obj$alpha)),
sprintf("Min = %.4f",    min(alsi_obj$alpha)),
sprintf("Max = %.4f",    max(alsi_obj$alpha)),
sprintf("Mean = %.4f",   mean(alsi_obj$alpha))),
bty = "n", cex = 0.85)
## ^^^ Figure 3 displayed here
## =============================================================================
## Section 4.5 — Category projections
## Projection table only — no biplot produced
## =============================================================================
cat("\n--- Section 4.5: Category projections ---\n")
Gk   <- fit$G[, 1:pa$K_star, drop = FALSE]
proj <- drop(Gk %*% alsi_obj$alpha_vec)
ord  <- order(abs(proj), decreasing = TRUE)
cat("\nTop 10 categories by |projection onto ALSI direction|:\n")
print(data.frame(Category   = rownames(Gk)[ord[1:10]],
Projection = round(proj[ord[1:10]], 4)),
row.names = FALSE)
## Expected:
##  ADHD_1  -2.0696
##   DYS_1  -1.1949
##   DEP_1  -0.9841
##  PTSD_1  -0.9067
##   MDD_1   0.8628
##  SOPH_1   0.6951
##   MDD_0  -0.6870
##   DEP_0   0.5827
##   ANX_1  -0.3250
##   GAD_1   0.3188
cat("\nFull projection table (all 18 categories):\n")
print(data.frame(Category   = rownames(Gk)[ord],
Projection = round(proj[ord], 4)),
row.names = FALSE)
## =============================================================================
## Section 4.6 — Downstream analyses
## =============================================================================
cat("\n--- Section 4.6: Downstream analyses ---\n")
ANR2$alpha <- alsi_obj$alpha
cat("\nModel 1: post_EDI ~ pre_EDI + alpha\n")
fit_edi <- lm(post_EDI ~ pre_EDI + alpha, data = ANR2)
print(summary(fit_edi))
cat("alpha coefficient:\n")
print(round(coef(summary(fit_edi))["alpha", ], 4))
## Expected: Estimate = 14.45, p = 0.005
cat("\nModel 2: post_bmi ~ pre_bmi + alpha\n")
fit_bmi <- lm(post_bmi ~ pre_bmi + alpha, data = ANR2)
print(summary(fit_bmi))
cat("alpha coefficient:\n")
print(round(coef(summary(fit_bmi))["alpha", ], 4))
## Expected: Estimate = -0.01, p = 0.943
## =============================================================================
## Section 4.7 — Complete workflow via alsi_workflow()
## All internal plots suppressed with pdf(NULL)/dev.off() to avoid
## duplicating Figures 1-3 and the category biplot already shown above
## =============================================================================
cat("\n--- Section 4.7: Complete workflow ---\n")
pdf(NULL)                                   # redirect all plots to null device
results <- alsi_workflow(ANR2,              # positional arg — avoids CRAN error
vars   = vars,
B_pa   = 2000,
B_boot = 2000,
seed   = 20260123)
dev.off()                                   # close null device
cat("\nWorkflow output components:\n")
cat("  pa$K_star    =", results$pa$K_star, "\n")   ## Expected: 3
cat("  boot$K       =", results$boot$K,    "\n")   ## Expected: 3
cat("  alsi$K       =", results$alsi$K,   "\n")   ## Expected: 3
cat("  K (retained) =", results$K,         "\n")   ## Expected: 3
## =============================================================================
## Session information
## =============================================================================
cat("\n--- Session information ---\n")
sessionInfo()
print(round(colMeans(ANR2[, vars], na.rm = TRUE), 3))
## NOTE: mca_pa() always plots Figure 1 internally. We call it once here.
## verbose = FALSE suppresses console clutter; K_star and % inertia shown below.
pa <- mca_pa(ANR2, vars = vars, B = 2000, q = 0.95,
seed = 20260123, verbose = TRUE)
cat("K* retained:", pa$K_star, "\n")
N_obs <- matrix(
c(
270,  25, 250,  44,  83,  97, 228,  16,
441,  25, 343,  92, 143, 195, 332,  47,
411, 101, 274,  91, 127, 171, 242,  42,
363,  71, 215,  98, 117, 160, 224,  39,
228,  54, 139,  69,  66, 100, 138,  27,
141,  33,  95,  54,  46,  54,  85,   8,
152,  23,  71,  48,  40,  62,  76,  15,
106,  21,  67,  44,  39,  37,  57,   5,
298,  66, 169, 121,  76, 138, 152,  21,
180,  32,  82,  64,  44,  68,  88,  18
),
nrow = 10, byrow = TRUE
)
total(N_obs)
sum(N_obs)
setwd("/Users/sekangkim/Documents/J_Sub/SEPA_pkg/")
devtools::document()   # regenerates .Rd files from roxygen
devtools::check()      # confirm 0 errors | 0 warnings | 0 notes
devtools::check_win_devel()
devtools::release()
